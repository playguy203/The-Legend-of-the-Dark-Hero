[sub_resource type="GDScript" id="GDScript_ij6vw"]
resource_name = "Movimiento"
script/source = "extends CharacterBody2D

@export var velocidad: float = 200.0

@onready var sprite: AnimatedSprite2D = $AnimatedSprite2D

# Guarda la última dirección para saber a qué 'idle' regresar
var ultima_direccion: Vector2 = Vector2.DOWN 

func _physics_process(_delta: float) -> void:
	# 1. Obtener la dirección usando tus nuevas acciones WASD
	var direccion: Vector2 = Input.get_vector(\"mover_izquierda\", \"mover_derecha\", \"mover_arriba\", \"mover_abajo\")
	
	# 2. Aplicar movimiento \"en seco\"
	if direccion != Vector2.ZERO:
		# Al normalizar evitamos que camine más rápido en diagonal
		velocity = direccion.normalized() * velocidad
		ultima_direccion = direccion
	else:
		# Freno en seco instantáneo
		velocity = Vector2.ZERO
	
	# Mover al personaje respetando colisiones
	move_and_slide()
	
	# 3. Controlar las animaciones
	actualizar_animacion(direccion)

func actualizar_animacion(direccion: Vector2) -> void:
	if direccion != Vector2.ZERO:
		# Prioriza la dirección horizontal si se mueve en diagonal
		if abs(direccion.x) > abs(direccion.y):
			if direccion.x > 0:
				sprite.play(\"caminar_derecha\")
			else:
				sprite.play(\"caminar_izquierda\")
		else:
			if direccion.y > 0:
				sprite.play(\"caminar_frente\")
			else:
				sprite.play(\"caminar_atras\")
	else:
		# Si está quieto, usamos la última dirección registrada para el Idle
		if abs(ultima_direccion.x) > abs(ultima_direccion.y):
			if ultima_direccion.x > 0:
				sprite.play(\"idle_derecha\")
			else:
				sprite.play(\"idle_izquierda\")
		else:
			if ultima_direccion.y > 0:
				sprite.play(\"idle_frente\")
			else:
				sprite.play(\"idle_atras\")
"

